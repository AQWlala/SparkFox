# Rust
/target/
**/target/
# Task-scoped Cargo target dirs from local test/debug runs
/build-task*/
/build.noindex/
/build.*.noindex/
Cargo.lock.bak

# Review reports (temporary)
docs/SparkFox-*.md

# Packaging / runtime artifacts
/dist/
# Legacy dev data dirs from before all hosts shared one per-user default
# (%LOCALAPPDATA%\NomiFun\Nomi etc.) — kept so stale checkouts don't commit them.
/data/
/data-verify/
/.dev-data/
# Per-crate runtime data (app state written at runtime, e.g. extension-states.json)
crates/backend/sparkfox-be-app/data/

# Node / Bun
node_modules/
**/node_modules/
ui/dist/
.bun/
*.tsbuildinfo

# The root bun.lock is canonical for the Bun workspace. Do not commit a
# second lockfile generated by running `bun install` from ui/.
/ui/bun.lock

# One-off local visual QA artifacts belong in the ignored .superpowers/ area,
# not in the repository root or source directories.
/design-qa.md
/ui/_shot_*.py

# Tauri
apps/desktop/gen/
apps/desktop/target/

# Tauri updater signing keys — NEVER commit private keys
apps/desktop/.tauri/
*.key
# The matching public key lives in tauri.conf.json (plugins.updater.pubkey);
# keep the local .pub copy out of git to avoid a stray untracked file.
*.key.pub

# macOS code signing / notarization secrets — NEVER commit
apps/desktop/signing/.env.signing

# Release upload token for `bun run release:win` — NEVER commit (holds a GitHub PAT).
# The .example alongside it is safe to track.
apps/desktop/signing/.env.release
*.p8
*.p12
*.cer
*.mobileprovision

# Logs / OS
*.log
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# Claude Code 会话产物（临时 worktree、本地设置），不入库
.claude/

# Visual brainstorming companion (transient mockups)
.superpowers/

# Isolated Codex development worktrees
.worktrees/

# SparkFox: 预下载的 bge 模型（PoC-3 测试用，120MB+，不入库）
# 运行时通过 SPARKFOX_MODELS_DIR 环境变量或 hf-hub 缓存加载
/.models/

# v1.1.0 HnswIndex 选型评估 PoC 构建产物（源码 Cargo.toml + src/ 保留）
# 现有 /build.noindex/ 只匹配根目录，补充 **/ 匹配子目录
**/build.noindex/
**/build.*.noindex/
**/bench/alternatives/*/target/

# TRAE IDE 会话产物（技能定义 / 临时日志），不入库
.trae/

# TDD 日志目录（验收脚本 + 临时日志，仅本地参考）
docs/tdd_logs/
