{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SparkFox",
  "identifier": "com.sparkfox.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --filter=./ui dev",
    "beforeBuildCommand": "bun scripts/prune-build.mjs --pre && bun run --filter=./ui build"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' tauri:; img-src 'self' data: blob: tauri: https:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https:; font-src 'self' data: tauri:; style-src 'self' 'unsafe-inline' tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval' tauri:; frame-src 'self' tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "resources": ["../../ui/dist"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sparkfox"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/sparkfox/sparkfox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzQUEyNzJFNjBBQTc5NTIKUldSU2VhcGdMaWVxODRRbUdXczZodEJZOE1Ja2Zta011eWUxUko2SG5XclVaSUdtaWNobXJNemEK"
    }
  }
}
